# Required in production
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
APP_SECRET="replace-with-a-long-random-string"

# Required for outgoing email notifications
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="Chicago Restaurant Dashboard <updates@yourdomain.com>"

# Required if you call protected event-capture routes manually
CRON_SECRET="replace-with-a-long-random-string"

# Optional for local Postgres without SSL
# PGSSLMODE="disable"

# Recommended for providers with a private CA (for example Supabase): paste
# the provider's CA certificate (PEM). Literal \n sequences are accepted.
# Supabase: Project Settings -> Database -> SSL Configuration -> Download certificate.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Last-resort escape hatch for providers with self-signed certificates when a
# CA cert is unavailable. Keeps TLS but disables certificate checks.
# DATABASE_SSL_NO_VERIFY="1"
