# Required in production
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
APP_SECRET="replace-with-a-long-random-string"

# Required for outgoing email notifications
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="Chicago Restaurant Dashboard <updates@yourdomain.com>"

# Required if you call protected event-capture routes manually
CRON_SECRET="replace-with-a-long-random-string"

# Optional for local Postgres without SSL
# PGSSLMODE="disable"
